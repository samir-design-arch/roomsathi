      "html": "<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Montserrat:wght@500;600;700;800&family=Merriweather:wght@300;400;700&display=swap');\n  @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n\n  :root {\n    --charcoal-blue: #36454F;\n    --warm-alabaster: #FDFCF7;\n    --navy-electric: #00009C;\n    --slate-200: #E2E8F0;\n    --slate-500: #64748B;\n    --success: #10B981;\n  }\n\n  body {\n    background-color: var(--warm-alabaster);\n    color: var(--charcoal-blue);\n    font-family: 'Merriweather', serif;\n    margin: 0;\n  }\n\n  h1, h2, h3, h4, h5, h6 {\n    font-family: 'Montserrat', sans-serif;\n    font-weight: 700;\n    margin: 0;\n  }\n\n  .font-heading { font-family: 'Montserrat', sans-serif; }\n  .font-body { font-family: 'Merriweather', serif; }\n\n  /* Custom Scrollbar for list */\n  .custom-scrollbar::-webkit-scrollbar {\n    width: 6px;\n  }\n  .custom-scrollbar::-webkit-scrollbar-track {\n    background: transparent;\n  }\n  .custom-scrollbar::-webkit-scrollbar-thumb {\n    background: var(--slate-200);\n    border-radius: 10px;\n  }\n</style>\n\n<div class=\"flex flex-col h-screen overflow-hidden\" data-kid=\"1\">\n  \n  <header class=\"sticky top-0 z-50 bg-white border-b border-[var(--slate-200)] px-8 h-20 flex items-center shrink-0\" data-kid=\"2\">\n    <div class=\"flex items-center gap-12 w-full max-w-[1440px] mx-auto\" data-kid=\"3\">\n      \n      <a href=\"#\" class=\"flex items-center gap-2 group\" data-kid=\"4\">\n        <div class=\"w-10 h-10 bg-[var(--charcoal-blue)] rounded flex items-center justify-center text-white text-xl\" data-kid=\"5\">\n          <i class=\"ti ti-home-check\" data-kid=\"6\"></i>\n        </div>\n        <span class=\"font-heading text-2xl font-800 tracking-tighter text-[var(--charcoal-blue)]\" data-kid=\"7\">RoomSathi</span>\n      </a>\n\n      \n      <div class=\"flex-1 max-w-2xl relative\" data-kid=\"8\">\n        <div class=\"flex items-center bg-[var(--warm-alabaster)] border border-[var(--slate-200)] rounded-lg px-4 h-12 gap-3 focus-within:border-[var(--navy-electric)] focus-within:ring-1 focus-within:ring-[var(--navy-electric)] transition-all\" data-kid=\"9\">\n          <i class=\"ti ti-search text-[var(--slate-500)] text-lg\" data-kid=\"10\"></i>\n          <input type=\"text\" placeholder=\"Search by college, area, or budget...\" class=\"bg-transparent border-none outline-none w-full text-sm font-body italic\" data-kid=\"11\">\n          <div class=\"flex items-center gap-1 bg-white border border-[var(--slate-200)] rounded px-1.5 py-0.5 text-[10px] font-heading font-600 text-[var(--slate-500)] uppercase tracking-wider\" data-kid=\"12\">\n            <span data-kid=\"13\">Cmd</span>\n            <span data-kid=\"14\">K</span>\n          </div>\n        </div>\n      </div>\n\n      \n      <nav class=\"flex items-center gap-8 font-heading text-sm font-600 uppercase tracking-widest text-[var(--charcoal-blue)]\" data-kid=\"15\">\n        <a href=\"#\" class=\"hover:text-[var(--navy-electric)] transition-colors border-b-2 border-transparent hover:border-[var(--navy-electric)] py-1\" data-kid=\"16\">List Property</a>\n        <a href=\"#\" class=\"hover:text-[var(--navy-electric)] transition-colors border-b-2 border-transparent hover:border-[var(--navy-electric)] py-1\" data-kid=\"17\">Dashboard</a>\n      </nav>\n\n      \n      <div class=\"flex items-center gap-4\" data-kid=\"18\">\n        <button class=\"relative w-10 h-10 rounded-full hover:bg-[var(--warm-alabaster)] flex items-center justify-center transition-colors\" data-kid=\"19\">\n          <i class=\"ti ti-bell text-xl\" data-kid=\"20\"></i>\n          <span class=\"absolute top-2 right-2 w-2 h-2 bg-red-500 rounded-full border-2 border-white\" data-kid=\"21\"></span>\n        </button>\n        <div class=\"w-10 h-10 rounded-full bg-[var(--charcoal-blue)] flex items-center justify-center text-white font-heading font-700 text-sm cursor-pointer border-2 border-transparent hover:border-[var(--navy-electric)] transition-all\" data-kid=\"22\">\n          AS\n        </div>\n      </div>\n    </div>\n  </header>\n\n  \n  <main class=\"flex flex-1 overflow-hidden\" data-kid=\"23\">\n    \n    \n    <div class=\"w-1/2 flex flex-col bg-white overflow-hidden border-r border-[var(--slate-200)]\" data-kid=\"24\">\n      \n      <div class=\"px-8 py-4 border-b border-[var(--slate-200)] flex items-center justify-between shrink-0\" data-kid=\"25\">\n        <div class=\"flex items-center gap-3\" data-kid=\"26\">\n          <span class=\"font-heading text-xs font-700 uppercase tracking-widest text-[var(--slate-500)]\" data-kid=\"27\">8 Properties Found</span>\n        </div>\n        <div class=\"flex items-center gap-2\" data-kid=\"28\">\n          <button class=\"flex items-center gap-2 px-4 py-2 border border-[var(--slate-200)] rounded-full font-heading text-[10px] font-700 uppercase tracking-wider hover:bg-[var(--warm-alabaster)] transition-colors\" data-kid=\"29\">\n            <i class=\"ti ti-adjustments-horizontal text-base\" data-kid=\"30\"></i> Filters\n          </button>\n          <div class=\"h-4 w-px bg-[var(--slate-200)] mx-2\" data-kid=\"31\"></div>\n          <select class=\"bg-transparent font-heading text-[10px] font-700 uppercase tracking-wider outline-none cursor-pointer\" data-kid=\"32\">\n            <option data-kid=\"33\">Recommended</option>\n            <option data-kid=\"34\">Price: Low to High</option>\n            <option data-kid=\"35\">Safety Score</option>\n          </select>\n        </div>\n      </div>\n\n      \n      <div class=\"flex-1 overflow-y-auto custom-scrollbar px-8 py-8 space-y-8 bg-[var(--warm-alabaster)]\" data-kid=\"36\">\n        \n        \n        <div class=\"flex flex-col bg-white rounded-xl border border-[var(--slate-200)] overflow-hidden hover:shadow-[0_20px_40px_rgba(54,69,79,0.08)] transition-all group\" data-kid=\"37\">\n          <div class=\"flex h-64\" data-kid=\"38\">\n            \n            <div class=\"w-2/5 relative overflow-hidden shrink-0\" data-kid=\"39\">\n              <img src=\"https://images.unsplash.com/photo-1522708323590-d24dbb6b0267?auto=format&w=600&q=80&fit=crop\" class=\"w-full h-full object-cover transition-transform duration-700 group-hover:scale-105\" alt=\"Modern Studio Room\" decoding=\"async\" loading=\"lazy\" data-kid=\"40\">\n              <div class=\"absolute top-4 left-4 flex flex-col gap-2\" data-kid=\"41\">\n                <span class=\"bg-white/90 backdrop-blur-md px-3 py-1 rounded-sm text-[10px] font-heading font-700 uppercase tracking-widest flex items-center gap-1.5 shadow-sm\" data-kid=\"42\">\n                  <i class=\"ti ti-discount-check-filled text-[var(--success)] text-sm\" data-kid=\"43\"></i> Verified Property\n                </span>\n              </div>\n              <button class=\"absolute top-4 right-4 w-8 h-8 rounded-full bg-white/80 backdrop-blur-sm flex items-center justify-center hover:bg-white transition-colors text-[var(--charcoal-blue)]\" data-kid=\"44\">\n                <i class=\"ti ti-heart\" data-kid=\"45\"></i>\n              </button>\n            </div>\n            \n            \n            <div class=\"flex-1 p-6 flex flex-col justify-between\" data-kid=\"46\">\n              <div data-kid=\"47\">\n                <div class=\"flex items-center justify-between mb-2\" data-kid=\"48\">\n                  <span class=\"font-heading text-[10px] font-700 text-[var(--navy-electric)] uppercase tracking-widest\" data-kid=\"49\">Lalitpur • 0.5 km from Campus</span>\n                  <span class=\"font-heading text-lg font-800 text-[var(--charcoal-blue)]\" data-kid=\"50\">NPR 15,000<span class=\"text-xs font-body font-400 text-[var(--slate-500)] tracking-normal italic\" data-kid=\"51\"> / month</span></span>\n                </div>\n                <h3 class=\"text-xl leading-tight mb-4 group-hover:text-[var(--navy-electric)] transition-colors\" data-kid=\"52\">Modern Studio Apartment near Pulchowk Campus</h3>\n                \n                \n                <div class=\"flex items-center gap-6 py-4 border-y border-[var(--slate-200)]/50 mb-4\" data-kid=\"53\">\n                  <div class=\"flex items-center gap-2\" data-kid=\"54\">\n                    <div class=\"w-8 h-8 rounded-full bg-[var(--warm-alabaster)] flex items-center justify-center text-[var(--navy-electric)]\" data-kid=\"55\">\n                      <i class=\"ti ti-id-badge-2 text-lg\" data-kid=\"56\"></i>\n                    </div>\n                    <div class=\"flex flex-col\" data-kid=\"57\">\n                      <span class=\"text-[9px] font-heading font-700 text-[var(--slate-500)] uppercase tracking-wider\" data-kid=\"58\">Identity</span>\n                      <span class=\"text-[11px] font-heading font-600\" data-kid=\"59\">Verified Host</span>\n                    </div>\n                  </div>\n                  <div class=\"flex items-center gap-2\" data-kid=\"60\">\n                    <div class=\"w-8 h-8 rounded-full bg-[var(--warm-alabaster)] flex items-center justify-center text-[var(--navy-electric)]\" data-kid=\"61\">\n                      <i class=\"ti ti-message-bolt text-lg\" data-kid=\"62\"></i>\n                    </div>\n                    <div class=\"flex flex-col\" data-kid=\"63\">\n                      <span class=\"text-[9px] font-heading font-700 text-[var(--slate-500)] uppercase tracking-wider\" data-kid=\"64\">Response</span>\n                      <span class=\"text-[11px] font-heading font-600\" data-kid=\"65\">95% in 5m</span>\n                    </div>\n                  </div>\n                  <div class=\"flex items-center gap-2\" data-kid=\"66\">\n                    <div class=\"w-8 h-8 rounded-full bg-[var(--warm-alabaster)] flex items-center justify-center text-[var(--success)]\" data-kid=\"67\">\n                      <i class=\"ti ti-shield-check text-lg\" data-kid=\"68\"></i>\n                    </div>\n                    <div class=\"flex flex-col\" data-kid=\"69\">\n                      <span class=\"text-[9px] font-heading font-700 text-[var(--slate-500)] uppercase tracking-wider\" data-kid=\"70\">Safety</span>\n                      <span class=\"text-[11px] font-heading font-600\" data-kid=\"71\">92/100 Score</span>\n                    </div>\n                  </div>\n                </div>\n              </div>\n\n              <div class=\"flex items-center justify-between\" data-kid=\"72\">\n                <div class=\"flex gap-2\" data-kid=\"73\">\n                  <span class=\"bg-[var(--warm-alabaster)] px-2 py-1 rounded text-[10px] font-heading font-600 text-[var(--slate-500)]\" data-kid=\"74\">Furnished</span>\n                  <span class=\"bg-[var(--warm-alabaster)] px-2 py-1 rounded text-[10px] font-heading font-600 text-[var(--slate-500)]\" data-kid=\"75\">WiFi Incl.</span>\n                </div>\n                <a href=\"#\" class=\"flex items-center gap-2 text-[var(--navy-electric)] font-heading text-xs font-700 uppercase tracking-widest hover:gap-3 transition-all\" data-kid=\"76\">\n                  View Details <i class=\"ti ti-arrow-narrow-right text-lg\" data-kid=\"77\"></i>\n                </a>\n              </div>\n            </div>\n          </div>\n        </div>\n\n        \n        <div class=\"flex flex-col bg-white rounded-xl border border-[var(--slate-200)] overflow-hidden hover:shadow-[0_20px_40px_rgba(54,69,79,0.08)] transition-all group\" data-kid=\"78\">\n          <div class=\"flex h-64\" data-kid=\"79\">\n            <div class=\"w-2/5 relative overflow-hidden shrink-0\" data-kid=\"80\">\n              <img src=\"https://images.unsplash.com/photo-1598928506311-c55ez2c0d8ea?auto=format&w=600&q=80&fit=crop\" class=\"w-full h-full object-cover transition-transform duration-700 group-hover:scale-105\" alt=\"Girls Hostel\" decoding=\"async\" loading=\"lazy\" data-kid=\"81\">\n              <div class=\"absolute top-4 left-4 flex flex-col gap-2\" data-kid=\"82\">\n                <span class=\"bg-white/90 backdrop-blur-md px-3 py-1 rounded-sm text-[10px] font-heading font-700 uppercase tracking-widest flex items-center gap-1.5 shadow-sm\" data-kid=\"83\">\n                  <i class=\"ti ti-discount-check-filled text-[var(--success)] text-sm\" data-kid=\"84\"></i> Verified Property\n                </span>\n              </div>\n            </div>\n            <div class=\"flex-1 p-6 flex flex-col justify-between\" data-kid=\"85\">\n              <div data-kid=\"86\">\n                <div class=\"flex items-center justify-between mb-2\" data-kid=\"87\">\n                  <span class=\"font-heading text-[10px] font-700 text-[var(--navy-electric)] uppercase tracking-widest\" data-kid=\"88\">Kirtipur • 1.2 km from TU</span>\n                  <span class=\"font-heading text-lg font-800 text-[var(--charcoal-blue)]\" data-kid=\"89\">NPR 8,000<span class=\"text-xs font-body font-400 text-[var(--slate-500)] tracking-normal italic\" data-kid=\"90\"> / month</span></span>\n                </div>\n                <h3 class=\"text-xl leading-tight mb-4 group-hover:text-[var(--navy-electric)] transition-colors\" data-kid=\"91\">Girls Hostel - Safe & Affordable Living</h3>\n                \n                \n                <div class=\"flex items-center gap-6 py-4 border-y border-[var(--slate-200)]/50 mb-4\" data-kid=\"92\">\n                  <div class=\"flex items-center gap-2\" data-kid=\"93\">\n                    <div class=\"w-8 h-8 rounded-full bg-[var(--warm-alabaster)] flex items-center justify-center text-[var(--navy-electric)]\" data-kid=\"94\">\n                      <i class=\"ti ti-id-badge-2 text-lg\" data-kid=\"95\"></i>\n                    </div>\n                    <div class=\"flex flex-col\" data-kid=\"96\">\n                      <span class=\"text-[9px] font-heading font-700 text-[var(--slate-500)] uppercase tracking-wider\" data-kid=\"97\">Identity</span>\n                      <span class=\"text-[11px] font-heading font-600\" data-kid=\"98\">Verified Host</span>\n                    </div>\n                  </div>\n                  <div class=\"flex items-center gap-2\" data-kid=\"99\">\n                    <div class=\"w-8 h-8 rounded-full bg-[var(--warm-alabaster)] flex items-center justify-center text-[var(--navy-electric)]\" data-kid=\"100\">\n                      <i class=\"ti ti-message-bolt text-lg\" data-kid=\"101\"></i>\n                    </div>\n                    <div class=\"flex flex-col\" data-kid=\"102\">\n                      <span class=\"text-[9px] font-heading font-700 text-[var(--slate-500)] uppercase tracking-wider\" data-kid=\"103\">Response</span>\n                      <span class=\"text-[11px] font-heading font-600\" data-kid=\"104\">88% in 15m</span>\n                    </div>\n                  </div>\n                  <div class=\"flex items-center gap-2\" data-kid=\"105\">\n                    <div class=\"w-8 h-8 rounded-full bg-[var(--warm-alabaster)] flex items-center justify-center text-[var(--success)]\" data-kid=\"106\">\n                      <i class=\"ti ti-shield-check text-lg\" data-kid=\"107\"></i>\n                    </div>\n                    <div class=\"flex flex-col\" data-kid=\"108\">\n                      <span class=\"text-[9px] font-heading font-700 text-[var(--slate-500)] uppercase tracking-wider\" data-kid=\"109\">Safety</span>\n                      <span class=\"text-[11px] font-heading font-600\" data-kid=\"110\">88/100 Score</span>\n                    </div>\n                  </div>\n                </div>\n              </div>\n              <div class=\"flex items-center justify-between\" data-kid=\"111\">\n                <div class=\"flex gap-2\" data-kid=\"112\">\n                  <span class=\"bg-[var(--warm-alabaster)] px-2 py-1 rounded text-[10px] font-heading font-600 text-[var(--slate-500)]\" data-kid=\"113\">Food Included</span>\n                  <span class=\"bg-[var(--warm-alabaster)] px-2 py-1 rounded text-[10px] font-heading font-600 text-[var(--slate-500)]\" data-kid=\"114\">Female Warden</span>\n                </div>\n                <a href=\"#\" class=\"flex items-center gap-2 text-[var(--navy-electric)] font-heading text-xs font-700 uppercase tracking-widest hover:gap-3 transition-all\" data-kid=\"115\">\n                  View Details <i class=\"ti ti-arrow-narrow-right text-lg\" data-kid=\"116\"></i>\n                </a>\n              </div>\n            </div>\n          </div>\n        </div>\n\n      </div>\n    </div>\n\n    \n    <div class=\"w-1/2 relative bg-[var(--slate-200)] flex items-center justify-center overflow-hidden\" data-kid=\"117\">\n      \n      <div class=\"absolute inset-0 opacity-40 mix-blend-multiply bg-[url('https://www.google.com/maps/vt/pb=!1m14!1m12!1m3!1d14131.52044816654!2d85.3239505!3d27.700769!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!5e0!3m2!1sen!2snp!4v1625293220464!5m2!1sen!2snp')] bg-cover grayscale\" data-kid=\"118\"></div>\n      \n      \n      <div class=\"absolute top-1/2 left-1/3 group cursor-pointer\" data-kid=\"119\">\n        <div class=\"relative flex flex-col items-center\" data-kid=\"120\">\n          <div class=\"bg-[var(--charcoal-blue)] text-white px-3 py-1 rounded-sm font-heading text-xs font-700 shadow-xl group-hover:bg-[var(--navy-electric)] transition-colors\" data-kid=\"121\">\n            NPR 15K\n          </div>\n          <div class=\"w-3 h-3 bg-[var(--charcoal-blue)] rotate-45 -mt-1 group-hover:bg-[var(--navy-electric)] transition-colors\" data-kid=\"122\"></div>\n        </div>\n      </div>\n\n      <div class=\"absolute top-1/4 right-1/4 group cursor-pointer\" data-kid=\"123\">\n        <div class=\"relative flex flex-col items-center\" data-kid=\"124\">\n          <div class=\"bg-[var(--charcoal-blue)] text-white px-3 py-1 rounded-sm font-heading text-xs font-700 shadow-xl group-hover:bg-[var(--navy-electric)] transition-colors\" data-kid=\"125\">\n            NPR 8K\n          </div>\n          <div class=\"w-3 h-3 bg-[var(--charcoal-blue)] rotate-45 -mt-1 group-hover:bg-[var(--navy-electric)] transition-colors\" data-kid=\"126\"></div>\n        </div>\n      </div>\n\n      <div class=\"absolute bottom-1/3 right-1/3 group cursor-pointer\" data-kid=\"127\">\n        <div class=\"relative flex flex-col items-center\" data-kid=\"128\">\n          <div class=\"bg-[var(--charcoal-blue)] text-white px-3 py-1 rounded-sm font-heading text-xs font-700 shadow-xl group-hover:bg-[var(--navy-electric)] transition-colors\" data-kid=\"129\">\n            NPR 25K\n          </div>\n          <div class=\"w-3 h-3 bg-[var(--charcoal-blue)] rotate-45 -mt-1 group-hover:bg-[var(--navy-electric)] transition-colors\" data-kid=\"130\"></div>\n        </div>\n      </div>\n\n      \n      <div class=\"absolute bottom-8 right-8 flex flex-col gap-2\" data-kid=\"131\">\n        <div class=\"bg-white border border-[var(--slate-200)] rounded-lg p-1 flex flex-col shadow-lg\" data-kid=\"132\">\n          <button class=\"w-10 h-10 flex items-center justify-center hover:bg-[var(--warm-alabaster)] rounded transition-colors\" data-kid=\"133\"><i class=\"ti ti-plus\" data-kid=\"134\"></i></button>\n          <div class=\"h-px bg-[var(--slate-200)] w-6 mx-auto\" data-kid=\"135\"></div>\n          <button class=\"w-10 h-10 flex items-center justify-center hover:bg-[var(--warm-alabaster)] rounded transition-colors\" data-kid=\"136\"><i class=\"ti ti-minus\" data-kid=\"137\"></i></button>\n        </div>\n        <button class=\"w-12 h-12 bg-white border border-[var(--slate-200)] rounded-lg flex items-center justify-center shadow-lg hover:bg-[var(--warm-alabaster)] transition-colors\" data-kid=\"138\">\n          <i class=\"ti ti-current-location text-[var(--navy-electric)] text-xl\" data-kid=\"139\"></i>\n        </button>\n      </div>\n\n      \n      <div class=\"absolute bottom-8 left-8\" data-kid=\"140\">\n        <button class=\"bg-[var(--charcoal-blue)] text-white pl-4 pr-6 py-4 rounded-full flex items-center gap-3 shadow-[0_10px_30px_rgba(54,69,79,0.3)] hover:bg-[var(--navy-electric)] transition-all group scale-100 hover:scale-105\" data-kid=\"141\">\n          <div class=\"w-8 h-8 rounded-full bg-white/20 flex items-center justify-center\" data-kid=\"142\">\n            <i class=\"ti ti-robot text-lg\" data-kid=\"143\"></i>\n          </div>\n          <div class=\"flex flex-col items-start\" data-kid=\"144\">\n            <span class=\"font-heading text-[10px] font-700 uppercase tracking-widest text-white/60\" data-kid=\"145\">Housing Concierge</span>\n            <span class=\"font-heading text-sm font-700\" data-kid=\"146\">Ask Sathi AI</span>\n          </div>\n        </button>\n      </div>\n    </div>\n  </main>\n</div>",

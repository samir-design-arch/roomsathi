      "html": "<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Urbanist:wght@400;500;600;700&family=Public+Sans:wght@300;400;500;600&display=swap');\n\n  :root {\n    --brand-teal: #008080;\n    --cool-steel: #91A3B0;\n    --pure-white: #FFFFFF;\n    --slate-900: #0F172A;\n    --slate-50: #F8FAFC;\n  }\n\n  .font-heading { font-family: 'Urbanist', sans-serif; }\n  .font-body { font-family: 'Public Sans', sans-serif; }\n\n  /* Map stylized placeholder */\n  .map-bg {\n    background-color: #e5e7eb;\n    background-image: \n      radial-gradient(#d1d5db 2px, transparent 2px),\n      linear-gradient(rgba(209, 213, 223, 0.3) 1px, transparent 1px),\n      linear-gradient(90deg, rgba(209, 213, 223, 0.3) 1px, transparent 1px);\n    background-size: 40px 40px, 100px 100px, 100px 100px;\n  }\n\n  .custom-scrollbar::-webkit-scrollbar {\n    width: 4px;\n  }\n  .custom-scrollbar::-webkit-scrollbar-track {\n    background: transparent;\n  }\n  .custom-scrollbar::-webkit-scrollbar-thumb {\n    background: var(--cool-steel);\n    border-radius: 10px;\n  }\n\n  .ai-pulse {\n    box-shadow: 0 0 0 0 rgba(0, 128, 128, 0.4);\n    animation: pulse 2s infinite;\n  }\n\n  @keyframes pulse {\n    0% { transform: scale(0.95); box-shadow: 0 0 0 0 rgba(0, 128, 128, 0.7); }\n    70% { transform: scale(1); box-shadow: 0 0 0 10px rgba(0, 128, 128, 0); }\n    100% { transform: scale(0.95); box-shadow: 0 0 0 0 rgba(0, 128, 128, 0); }\n  }\n</style>\n\n<link rel=\"stylesheet\" href=\"https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css\" data-kid=\"1\">\n\n<div class=\"flex h-screen w-full bg-white text-[var(--slate-900)] font-body antialiased\" data-kid=\"2\">\n  \n  \n  <aside class=\"flex flex-col w-72 border-r border-[var(--cool-steel)]/30 h-full bg-[var(--slate-50)]/50 z-20\" data-kid=\"3\">\n    <div class=\"p-8\" data-kid=\"4\">\n      <div class=\"flex items-center gap-2 mb-12\" data-kid=\"5\">\n        <div class=\"w-8 h-8 bg-[var(--brand-teal)] rounded flex items-center justify-center text-white\" data-kid=\"6\">\n          <i class=\"ti ti-map-search text-xl\" data-kid=\"7\"></i>\n        </div>\n        <span class=\"font-heading font-bold text-xl tracking-tight\" data-kid=\"8\">RoomSathi</span>\n      </div>\n\n      <nav class=\"space-y-1 mb-12\" data-kid=\"9\">\n        <a href=\"#\" class=\"flex items-center gap-3 px-3 py-2 text-[var(--brand-teal)] bg-[var(--brand-teal)]/5 rounded-md font-medium transition-colors\" data-kid=\"10\">\n          <i class=\"ti ti-search text-lg\" data-kid=\"11\"></i>\n          <span data-kid=\"12\">Scout Housing</span>\n        </a>\n        <a href=\"#\" class=\"flex items-center gap-3 px-3 py-2 text-[var(--cool-steel)] hover:text-[var(--slate-900)] rounded-md font-medium transition-colors\" data-kid=\"13\">\n          <i class=\"ti ti-heart text-lg\" data-kid=\"14\"></i>\n          <span data-kid=\"15\">Saved</span>\n        </a>\n        <a href=\"#\" class=\"flex items-center gap-3 px-3 py-2 text-[var(--cool-steel)] hover:text-[var(--slate-900)] rounded-md font-medium transition-colors\" data-kid=\"16\">\n          <i class=\"ti ti-calendar-event text-lg\" data-kid=\"17\"></i>\n          <span data-kid=\"18\">Visits</span>\n        </a>\n        <a href=\"#\" class=\"flex items-center gap-3 px-3 py-2 text-[var(--cool-steel)] hover:text-[var(--slate-900)] rounded-md font-medium transition-colors\" data-kid=\"19\">\n          <i class=\"ti ti-message-2 text-lg\" data-kid=\"20\"></i>\n          <span data-kid=\"21\">Messages</span>\n        </a>\n      </nav>\n\n      <div class=\"space-y-6 overflow-y-auto custom-scrollbar pr-2 max-h-[calc(100vh-450px)]\" data-kid=\"22\">\n        <div data-kid=\"23\">\n          <label class=\"text-[10px] font-bold uppercase tracking-widest text-[var(--cool-steel)] mb-3 block\" data-kid=\"24\">Primary Filters</label>\n          <div class=\"space-y-4\" data-kid=\"25\">\n            <div class=\"group\" data-kid=\"26\">\n              <span class=\"text-xs font-semibold block mb-2\" data-kid=\"27\">Location</span>\n              <select class=\"w-full bg-white border border-[var(--cool-steel)]/30 rounded px-3 py-2 text-sm outline-none focus:border-[var(--brand-teal)] transition-colors appearance-none\" data-kid=\"28\">\n                <option data-kid=\"29\">Kathmandu Valley</option>\n                <option data-kid=\"30\">Pulchowk</option>\n                <option data-kid=\"31\">Baneshwor</option>\n              </select>\n            </div>\n            <div class=\"group\" data-kid=\"32\">\n              <span class=\"text-xs font-semibold block mb-2\" data-kid=\"33\">Monthly Budget</span>\n              <div class=\"flex items-center gap-2\" data-kid=\"34\">\n                <input type=\"text\" placeholder=\"Min\" class=\"w-full bg-white border border-[var(--cool-steel)]/30 rounded px-3 py-2 text-sm outline-none focus:border-[var(--brand-teal)]\" data-kid=\"35\">\n                <span class=\"text-[var(--cool-steel)] text-xs\" data-kid=\"36\">—</span>\n                <input type=\"text\" placeholder=\"Max\" class=\"w-full bg-white border border-[var(--cool-steel)]/30 rounded px-3 py-2 text-sm outline-none focus:border-[var(--brand-teal)]\" data-kid=\"37\">\n              </div>\n            </div>\n          </div>\n        </div>\n\n        <div data-kid=\"38\">\n          <label class=\"text-[10px] font-bold uppercase tracking-widest text-[var(--cool-steel)] mb-3 block\" data-kid=\"39\">Housing Type</label>\n          <div class=\"grid grid-cols-2 gap-2\" data-kid=\"40\">\n            <button class=\"px-3 py-2 border border-[var(--brand-teal)] bg-[var(--brand-teal)]/5 text-[var(--brand-teal)] rounded text-xs font-semibold\" data-kid=\"41\">Hostels</button>\n            <button class=\"px-3 py-2 border border-[var(--cool-steel)]/30 text-[var(--slate-900)] rounded text-xs font-semibold hover:bg-white transition-colors\" data-kid=\"42\">Apartments</button>\n            <button class=\"px-3 py-2 border border-[var(--cool-steel)]/30 text-[var(--slate-900)] rounded text-xs font-semibold hover:bg-white transition-colors\" data-kid=\"43\">Single Room</button>\n            <button class=\"px-3 py-2 border border-[var(--cool-steel)]/30 text-[var(--slate-900)] rounded text-xs font-semibold hover:bg-white transition-colors\" data-kid=\"44\">Shared Flat</button>\n          </div>\n        </div>\n      </div>\n    </div>\n\n    \n    <div class=\"mt-auto p-6\" data-kid=\"45\">\n      <div class=\"bg-white border border-[var(--cool-steel)]/20 rounded-xl p-4 shadow-sm\" data-kid=\"46\">\n        <div class=\"flex items-center gap-3 mb-3\" data-kid=\"47\">\n          <div class=\"w-2 h-2 rounded-full bg-[var(--brand-teal)] ai-pulse\" data-kid=\"48\"></div>\n          <span class=\"text-xs font-bold font-heading\" data-kid=\"49\">AI Housing Concierge</span>\n        </div>\n        <p class=\"text-[11px] text-[var(--cool-steel)] leading-relaxed mb-4\" data-kid=\"50\">\n          \"I need a quiet room under NPR 10k near Pulchowk with fast WiFi.\"\n        </p>\n        <button class=\"w-full bg-[var(--brand-teal)] text-white py-2 rounded-lg text-xs font-bold hover:bg-[#006666] transition-colors flex items-center justify-center gap-2\" data-kid=\"51\">\n          <i class=\"ti ti-message-chatbot text-base\" data-kid=\"52\"></i>\n          Start Intelligent Search\n        </button>\n      </div>\n      <div class=\"mt-6 flex items-center gap-3 px-2\" data-kid=\"53\">\n        <img src=\"https://i.pravatar.cc/100?u=anjali\" class=\"w-8 h-8 rounded-full bg-slate-200\" alt=\"Anjali\" decoding=\"async\" loading=\"lazy\" data-kid=\"54\">\n        <div class=\"flex flex-col\" data-kid=\"55\">\n          <span class=\"text-xs font-bold\" data-kid=\"56\">Anjali Sharma</span>\n          <span class=\"text-[10px] text-[var(--cool-steel)]\" data-kid=\"57\">Student @ Pulchowk</span>\n        </div>\n        <button class=\"ml-auto text-[var(--cool-steel)] hover:text-[var(--slate-900)]\" data-kid=\"58\">\n          <i class=\"ti ti-settings text-lg\" data-kid=\"59\"></i>\n        </button>\n      </div>\n    </div>\n  </aside>\n\n  \n  <main class=\"flex-1 relative overflow-hidden flex\" data-kid=\"60\">\n    \n    \n    <div class=\"absolute top-8 left-1/2 -translate-x-1/2 z-10 w-full max-w-2xl\" data-kid=\"61\">\n      <div class=\"bg-white/80 backdrop-blur-md border border-[var(--cool-steel)]/30 rounded-full py-3 px-6 shadow-xl flex items-center gap-4\" data-kid=\"62\">\n        <div class=\"flex items-center gap-2 flex-1 border-r border-[var(--cool-steel)]/20\" data-kid=\"63\">\n          <i class=\"ti ti-map-pin text-[var(--brand-teal)]\" data-kid=\"64\"></i>\n          <input type=\"text\" placeholder=\"Search areas, colleges, or landmarks...\" class=\"bg-transparent border-none outline-none text-sm w-full font-medium placeholder:text-[var(--cool-steel)]\" data-kid=\"65\">\n        </div>\n        <div class=\"flex items-center gap-6 px-4\" data-kid=\"66\">\n          <div class=\"flex flex-col\" data-kid=\"67\">\n            <span class=\"text-[9px] font-bold text-[var(--cool-steel)] uppercase tracking-tighter leading-none mb-1\" data-kid=\"68\">Check-in</span>\n            <span class=\"text-xs font-bold\" data-kid=\"69\">Jul 15, 2024</span>\n          </div>\n          <div class=\"w-8 h-8 bg-[var(--brand-teal)] rounded-full flex items-center justify-center text-white cursor-pointer hover:bg-[#006666] transition-transform hover:scale-105 active:scale-95\" data-kid=\"70\">\n            <i class=\"ti ti-search text-lg\" data-kid=\"71\"></i>\n          </div>\n        </div>\n      </div>\n    </div>\n\n    \n    <div class=\"absolute inset-0 map-bg z-0\" data-kid=\"72\">\n      \n      <div class=\"absolute top-[40%] left-[30%] group\" data-kid=\"73\">\n        <div class=\"flex flex-col items-center cursor-pointer\" data-kid=\"74\">\n          <div class=\"bg-white border-2 border-[var(--brand-teal)] text-[var(--brand-teal)] font-bold text-xs px-2 py-1 rounded shadow-lg transition-transform group-hover:scale-110\" data-kid=\"75\">NPR 15k</div>\n          <div class=\"w-0 h-0 border-l-[6px] border-l-transparent border-r-[6px] border-r-transparent border-t-[8px] border-t-[var(--brand-teal)]\" data-kid=\"76\"></div>\n        </div>\n      </div>\n      <div class=\"absolute top-[55%] left-[45%] group\" data-kid=\"77\">\n        <div class=\"flex flex-col items-center cursor-pointer\" data-kid=\"78\">\n          <div class=\"bg-[var(--brand-teal)] text-white font-bold text-xs px-2 py-1 rounded shadow-lg transition-transform group-hover:scale-110\" data-kid=\"79\">NPR 8k</div>\n          <div class=\"w-0 h-0 border-l-[6px] border-l-transparent border-r-[6px] border-r-transparent border-t-[8px] border-t-[var(--brand-teal)]\" data-kid=\"80\"></div>\n        </div>\n      </div>\n      <div class=\"absolute top-[25%] left-[60%] group\" data-kid=\"81\">\n        <div class=\"flex flex-col items-center cursor-pointer\" data-kid=\"82\">\n          <div class=\"bg-white border-2 border-[var(--brand-teal)] text-[var(--brand-teal)] font-bold text-xs px-2 py-1 rounded shadow-lg transition-transform group-hover:scale-110\" data-kid=\"83\">NPR 25k</div>\n          <div class=\"w-0 h-0 border-l-[6px] border-l-transparent border-r-[6px] border-r-transparent border-t-[8px] border-t-[var(--brand-teal)]\" data-kid=\"84\"></div>\n        </div>\n      </div>\n    </div>\n\n    \n    <section class=\"absolute right-0 top-0 bottom-0 w-[480px] bg-white z-10 border-l border-[var(--cool-steel)]/20 shadow-2xl flex flex-col\" data-kid=\"85\">\n      <div class=\"p-6 border-b border-[var(--cool-steel)]/10 flex items-center justify-between bg-white/80 backdrop-blur-sm sticky top-0 z-10\" data-kid=\"86\">\n        <div data-kid=\"87\">\n          <h2 class=\"font-heading font-bold text-lg\" data-kid=\"88\">Housing Scout</h2>\n          <p class=\"text-xs text-[var(--cool-steel)]\" data-kid=\"89\">8 verified matches near <span class=\"text-[var(--slate-900)] font-semibold underline underline-offset-4 decoration-[var(--brand-teal)]/30\" data-kid=\"90\">Pulchowk Campus</span></p>\n        </div>\n        <div class=\"flex gap-2\" data-kid=\"91\">\n          <button class=\"p-2 border border-[var(--cool-steel)]/30 rounded-lg hover:bg-[var(--slate-50)] transition-colors\" data-kid=\"92\"><i class=\"ti ti-adjustments-horizontal\" data-kid=\"93\"></i></button>\n          <button class=\"p-2 border border-[var(--cool-steel)]/30 rounded-lg hover:bg-[var(--slate-50)] transition-colors\" data-kid=\"94\"><i class=\"ti ti-layout-grid\" data-kid=\"95\"></i></button>\n        </div>\n      </div>\n\n      <div class=\"flex-1 overflow-y-auto p-6 space-y-8 custom-scrollbar\" data-kid=\"96\">\n        \n        \n        <article class=\"group\" data-kid=\"97\">\n          <div class=\"relative rounded-xl overflow-hidden aspect-[16/10] mb-4\" data-kid=\"98\">\n            <img src=\"https://images.unsplash.com/photo-1522708323590-d24dbb6b0267?auto=format&w=600&q=80&fit=crop\" class=\"w-full h-full object-cover transition-transform duration-500 group-hover:scale-105\" alt=\"Modern Studio\" decoding=\"async\" loading=\"lazy\" data-kid=\"99\">\n            <div class=\"absolute top-4 left-4 flex gap-2\" data-kid=\"100\">\n              <span class=\"bg-[var(--brand-teal)] text-white text-[10px] font-bold px-2 py-1 rounded flex items-center gap-1 shadow-lg\" data-kid=\"101\">\n                <i class=\"ti ti-sparkles\" data-kid=\"102\"></i> 98% Match\n              </span>\n              <span class=\"bg-white/90 backdrop-blur-sm text-[var(--slate-900)] text-[10px] font-bold px-2 py-1 rounded shadow-sm\" data-kid=\"103\">\n                Verified Host\n              </span>\n            </div>\n            <button class=\"absolute top-4 right-4 w-8 h-8 bg-white/20 backdrop-blur-md rounded-full flex items-center justify-center text-white hover:bg-white hover:text-red-500 transition-all\" data-kid=\"104\">\n              <i class=\"ti ti-heart\" data-kid=\"105\"></i>\n            </button>\n          </div>\n\n          <div class=\"flex justify-between items-start mb-2\" data-kid=\"106\">\n            <div data-kid=\"107\">\n              <h3 class=\"font-heading font-bold text-base leading-tight\" data-kid=\"108\">Modern Studio Apartment</h3>\n              <p class=\"text-xs text-[var(--cool-steel)] font-medium flex items-center gap-1\" data-kid=\"109\">\n                <i class=\"ti ti-map-pin\" data-kid=\"110\"></i> Pulchowk, Lalitpur • 0.5 km from Campus\n              </p>\n            </div>\n            <div class=\"text-right\" data-kid=\"111\">\n              <span class=\"text-lg font-heading font-extrabold text-[var(--brand-teal)]\" data-kid=\"112\">NPR 15,000</span>\n              <span class=\"text-[10px] block text-[var(--cool-steel)] uppercase font-bold tracking-tighter\" data-kid=\"113\">/month</span>\n            </div>\n          </div>\n\n          \n          <div class=\"grid grid-cols-3 gap-0 border border-[var(--cool-steel)]/20 rounded-lg overflow-hidden bg-[var(--slate-50)]/30 mt-4\" data-kid=\"114\">\n            <div class=\"p-3 border-r border-[var(--cool-steel)]/20 flex flex-col gap-1\" data-kid=\"115\">\n              <span class=\"text-[9px] font-bold text-[var(--cool-steel)] uppercase tracking-wider leading-none\" data-kid=\"116\">Response</span>\n              <span class=\"text-xs font-bold text-emerald-600 flex items-center gap-1\" data-kid=\"117\">\n                <i class=\"ti ti-clock-check\" data-kid=\"118\"></i> < 15m\n              </span>\n            </div>\n            <div class=\"p-3 border-r border-[var(--cool-steel)]/20 flex flex-col gap-1\" data-kid=\"119\">\n              <span class=\"text-[9px] font-bold text-[var(--cool-steel)] uppercase tracking-wider leading-none\" data-kid=\"120\">Safety</span>\n              <span class=\"text-xs font-bold\" data-kid=\"121\">92/100</span>\n            </div>\n            <div class=\"p-3 flex flex-col gap-1\" data-kid=\"122\">\n              <span class=\"text-[9px] font-bold text-[var(--cool-steel)] uppercase tracking-wider leading-none\" data-kid=\"123\">Visits</span>\n              <span class=\"text-xs font-bold\" data-kid=\"124\">24 this week</span>\n            </div>\n          </div>\n        </article>\n\n        \n        <article class=\"group\" data-kid=\"125\">\n          <div class=\"relative rounded-xl overflow-hidden aspect-[16/10] mb-4\" data-kid=\"126\">\n            <img src=\"https://images.unsplash.com/photo-1598928506311-c55ez2c0d8ea?auto=format&w=600&q=80&fit=crop\" class=\"w-full h-full object-cover transition-transform duration-500 group-hover:scale-105\" alt=\"Girls Hostel\" decoding=\"async\" loading=\"lazy\" data-kid=\"127\">\n            <div class=\"absolute top-4 left-4 flex gap-2\" data-kid=\"128\">\n              <span class=\"bg-[var(--brand-teal)] text-white text-[10px] font-bold px-2 py-1 rounded flex items-center gap-1 shadow-lg\" data-kid=\"129\">\n                <i class=\"ti ti-sparkles\" data-kid=\"130\"></i> 85% Match\n              </span>\n            </div>\n            <button class=\"absolute top-4 right-4 w-8 h-8 bg-white/20 backdrop-blur-md rounded-full flex items-center justify-center text-white hover:bg-white hover:text-red-500 transition-all\" data-kid=\"131\">\n              <i class=\"ti ti-heart\" data-kid=\"132\"></i>\n            </button>\n          </div>\n\n          <div class=\"flex justify-between items-start mb-2\" data-kid=\"133\">\n            <div data-kid=\"134\">\n              <h3 class=\"font-heading font-bold text-base leading-tight\" data-kid=\"135\">Elite Girls Hostel - Near TU</h3>\n              <p class=\"text-xs text-[var(--cool-steel)] font-medium flex items-center gap-1\" data-kid=\"136\">\n                <i class=\"ti ti-map-pin\" data-kid=\"137\"></i> Kirtipur, Kathmandu • 1.2 km from Campus\n              </p>\n            </div>\n            <div class=\"text-right\" data-kid=\"138\">\n              <span class=\"text-lg font-heading font-extrabold text-[var(--brand-teal)]\" data-kid=\"139\">NPR 8,000</span>\n              <span class=\"text-[10px] block text-[var(--cool-steel)] uppercase font-bold tracking-tighter\" data-kid=\"140\">/month</span>\n            </div>\n          </div>\n\n          \n          <div class=\"grid grid-cols-3 gap-0 border border-[var(--cool-steel)]/20 rounded-lg overflow-hidden bg-[var(--slate-50)]/30 mt-4\" data-kid=\"141\">\n            <div class=\"p-3 border-r border-[var(--cool-steel)]/20 flex flex-col gap-1\" data-kid=\"142\">\n              <span class=\"text-[9px] font-bold text-[var(--cool-steel)] uppercase tracking-wider leading-none\" data-kid=\"143\">Response</span>\n              <span class=\"text-xs font-bold text-amber-600 flex items-center gap-1\" data-kid=\"144\">\n                <i class=\"ti ti-clock\" data-kid=\"145\"></i> ~ 1h\n              </span>\n            </div>\n            <div class=\"p-3 border-r border-[var(--cool-steel)]/20 flex flex-col gap-1\" data-kid=\"146\">\n              <span class=\"text-[9px] font-bold text-[var(--cool-steel)] uppercase tracking-wider leading-none\" data-kid=\"147\">Safety</span>\n              <span class=\"text-xs font-bold\" data-kid=\"148\">88/100</span>\n            </div>\n            <div class=\"p-3 flex flex-col gap-1\" data-kid=\"149\">\n              <span class=\"text-[9px] font-bold text-[var(--cool-steel)] uppercase tracking-wider leading-none\" data-kid=\"150\">Amenities</span>\n              <span class=\"text-xs font-bold\" data-kid=\"151\">Food Included</span>\n            </div>\n          </div>\n        </article>\n\n        \n        <button class=\"w-full py-4 border-2 border-dashed border-[var(--cool-steel)]/20 rounded-xl text-[var(--cool-steel)] font-bold text-xs hover:border-[var(--brand-teal)]/30 hover:text-[var(--brand-teal)] transition-all flex items-center justify-center gap-2\" data-kid=\"152\">\n          Scout 12 more properties in this area <i class=\"ti ti-arrow-right\" data-kid=\"153\"></i>\n        </button>\n\n      </div>\n\n      \n      <div class=\"p-4 border-t border-[var(--cool-steel)]/10 bg-white\" data-kid=\"154\">\n        <div class=\"flex items-center justify-between text-[var(--cool-steel)] px-2 mb-2\" data-kid=\"155\">\n          <span class=\"text-[10px] font-bold uppercase tracking-widest\" data-kid=\"156\">Compare Scouted Items</span>\n          <span class=\"text-[10px] font-bold\" data-kid=\"157\">0/3 Selected</span>\n        </div>\n        <div class=\"flex gap-4\" data-kid=\"158\">\n          <button class=\"flex-1 bg-[var(--slate-900)] text-white py-3 rounded-lg text-sm font-bold hover:bg-black transition-colors\" data-kid=\"159\">Generate Comparison</button>\n          <button class=\"w-12 h-12 border border-[var(--cool-steel)]/30 rounded-lg flex items-center justify-center text-[var(--slate-900)] hover:bg-[var(--slate-50)] transition-colors\" data-kid=\"160\">\n            <i class=\"ti ti-share text-xl\" data-kid=\"161\"></i>\n          </button>\n        </div>\n      </div>\n    </section>\n\n  </main>\n</div>",

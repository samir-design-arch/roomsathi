      },
      "html": "<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;1,400;1,700&family=Source+Sans+3:wght@300;400;500;600;700&display=swap');\n  @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n\n  :root {\n    --bone-white: #F9F6F2;\n    --terracotta: #E07A5F;\n    --forest-green: #2E382E;\n    --sand: #EAE3D9;\n    --soft-border: rgba(46, 56, 46, 0.1);\n  }\n\n  body {\n    background-color: var(--bone-white);\n    color: var(--forest-green);\n    font-family: 'Source Sans 3', sans-serif;\n  }\n\n  .font-display { font-family: 'Playfair Display', serif; }\n  .font-body { font-family: 'Source Sans 3', sans-serif; }\n\n  .bg-bone { background-color: var(--bone-white); }\n  .bg-terracotta { background-color: var(--terracotta); }\n  .bg-forest { background-color: var(--forest-green); }\n  .text-forest { color: var(--forest-green); }\n  .text-terracotta { color: var(--terracotta); }\n  .border-forest { border-color: var(--soft-border); }\n\n  .organic-radius { border-radius: 40px 10px 40px 10px; }\n  .glass-nav {\n    background: rgba(249, 246, 242, 0.8);\n    backdrop-filter: blur(12px);\n    border-bottom: 1px solid var(--soft-border);\n  }\n\n  .property-card {\n    transition: transform 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);\n  }\n  .property-card:hover {\n    transform: translateY(-8px);\n  }\n\n  .hide-scrollbar::-webkit-scrollbar { display: none; }\n  .hide-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }\n</style>\n\n<div class=\"min-h-screen\" data-kid=\"1\">\n  \n  <nav class=\"glass-nav sticky top-0 z-50 py-4\" data-kid=\"2\">\n    <div class=\"container mx-auto px-8 flex items-center justify-between\" data-kid=\"3\">\n      <div class=\"flex items-center gap-12\" data-kid=\"4\">\n        <a href=\"#\" class=\"font-display text-3xl font-bold tracking-tight\" data-kid=\"5\">RoomSathi</a>\n        \n        \n        <div class=\"hidden md:flex items-center bg-white border border-forest rounded-full px-6 py-2 shadow-sm gap-4 w-[400px]\" data-kid=\"6\">\n          <i class=\"ti ti-search text-forest/50\" data-kid=\"7\"></i>\n          <input type=\"text\" placeholder=\"Search by college or area...\" class=\"bg-transparent border-none outline-none text-sm w-full font-medium\" data-kid=\"8\">\n          <div class=\"h-4 w-[1px] bg-forest/20\" data-kid=\"9\"></div>\n          <button class=\"text-xs font-bold whitespace-nowrap text-terracotta\" data-kid=\"10\">Filters</button>\n        </div>\n      </div>\n\n      <div class=\"flex items-center gap-6 font-semibold text-sm\" data-kid=\"11\">\n        <a href=\"#\" class=\"hover:text-terracotta transition-colors\" data-kid=\"12\">List your space</a>\n        <a href=\"#\" class=\"hover:text-terracotta transition-colors\" data-kid=\"13\">Find a roommate</a>\n        <div class=\"flex items-center gap-3 pl-4 border-l border-forest/10\" data-kid=\"14\">\n          <button class=\"w-10 h-10 rounded-full bg-forest text-bone flex items-center justify-center\" data-kid=\"15\">\n            <i class=\"ti ti-user\" data-kid=\"16\"></i>\n          </button>\n        </div>\n      </div>\n    </div>\n  </nav>\n\n  \n  <section class=\"container mx-auto px-8 py-16 grid lg:grid-cols-2 gap-16 items-center\" data-kid=\"17\">\n    <div class=\"space-y-8\" data-kid=\"18\">\n      <div class=\"inline-flex items-center gap-2 bg-sand/50 px-4 py-1.5 rounded-full border border-forest/10\" data-kid=\"19\">\n        <span class=\"w-2 h-2 rounded-full bg-terracotta animate-pulse\" data-kid=\"20\"></span>\n        <span class=\"text-xs font-bold tracking-widest uppercase\" data-kid=\"21\">Community Vetted</span>\n      </div>\n      <h1 class=\"font-display text-6xl lg:text-7xl leading-[1.1] font-bold\" data-kid=\"22\">\n        Find your <span class=\"italic text-terracotta\" data-kid=\"23\">sanctuary</span> in the heart of the valley.\n      </h1>\n      <p class=\"text-xl text-forest/70 max-width-xl leading-relaxed\" data-kid=\"24\">\n        A boutique collection of student homes, vouched for by your peers. No brokers, no hidden fees—just genuine spaces for Kathmandu's next generation.\n      </p>\n      <div class=\"flex items-center gap-4\" data-kid=\"25\">\n        <button class=\"bg-terracotta text-white px-8 py-4 rounded-full font-bold text-lg shadow-lg shadow-terracotta/20 hover:scale-105 transition-transform\" data-kid=\"26\">\n          Explore Rooms\n        </button>\n        <button class=\"flex items-center gap-3 text-forest font-bold px-8 py-4 hover:bg-forest/5 rounded-full transition-colors\" data-kid=\"27\">\n          <i class=\"ti ti-message-chatbot text-2xl text-terracotta\" data-kid=\"28\"></i>\n          Talk to our Concierge\n        </button>\n      </div>\n      \n      <div class=\"pt-8 flex items-center gap-8\" data-kid=\"29\">\n        <div class=\"flex -space-x-3\" data-kid=\"30\">\n          <img src=\"https://i.pravatar.cc/100?u=a\" class=\"w-12 h-12 rounded-full border-4 border-bone\" alt=\"Student\" data-kid=\"31\">\n          <img src=\"https://i.pravatar.cc/100?u=b\" class=\"w-12 h-12 rounded-full border-4 border-bone\" alt=\"Student\" data-kid=\"32\">\n          <img src=\"https://i.pravatar.cc/100?u=c\" class=\"w-12 h-12 rounded-full border-4 border-bone\" alt=\"Student\" data-kid=\"33\">\n          <div class=\"w-12 h-12 rounded-full bg-forest border-4 border-bone flex items-center justify-center text-bone text-xs font-bold\" data-kid=\"34\">\n            +5k\n          </div>\n        </div>\n        <p class=\"text-sm font-medium text-forest/60\" data-kid=\"35\">\n          Join <span class=\"text-forest font-bold\" data-kid=\"36\">5,000+ students</span> finding <br data-kid=\"37\">better housing together.\n        </p>\n      </div>\n    </div>\n    \n    <div class=\"relative\" data-kid=\"38\">\n      <div class=\"organic-radius overflow-hidden shadow-2xl shadow-forest/10 border-[12px] border-white\" data-kid=\"39\">\n        <img src=\"https://images.pexels.com/photos/7683902/pexels-photo-7683902.jpeg\" class=\"w-full aspect-[4/5] object-cover\" alt=\"Students laughing in Kathmandu\" decoding=\"async\" loading=\"lazy\" data-kid=\"40\">\n      </div>\n      \n      <div class=\"absolute -bottom-8 -left-8 bg-white p-6 rounded-2xl shadow-xl border border-forest/5 max-w-[240px]\" data-kid=\"41\">\n        <div class=\"flex items-center gap-3 mb-3\" data-kid=\"42\">\n          <div class=\"w-10 h-10 rounded-full bg-forest/5 flex items-center justify-center text-terracotta\" data-kid=\"43\">\n            <i class=\"ti ti-shield-check text-xl\" data-kid=\"44\"></i>\n          </div>\n          <span class=\"text-sm font-bold uppercase tracking-tighter\" data-kid=\"45\">Verified Host</span>\n        </div>\n        <p class=\"text-xs text-forest/60 leading-normal\" data-kid=\"46\">\n          \"I've hosted over 50 students from Pulchowk Engineering. My goal is to make your study years comfortable.\"\n        </p>\n        <div class=\"mt-3 text-xs font-bold text-forest\" data-kid=\"47\">— Rajesh KC</div>\n      </div>\n    </div>\n  </section>\n\n  \n  <section class=\"py-24 bg-sand/20\" data-kid=\"48\">\n    <div class=\"container mx-auto px-8\" data-kid=\"49\">\n      <div class=\"flex items-end justify-between mb-12\" data-kid=\"50\">\n        <div data-kid=\"51\">\n          <h2 class=\"font-display text-4xl font-bold mb-2\" data-kid=\"52\">Verified by your Campus</h2>\n          <p class=\"text-forest/60\" data-kid=\"53\">Top-rated spaces near major Kathmandu universities.</p>\n        </div>\n        <div class=\"flex gap-3\" data-kid=\"54\">\n          <button class=\"w-12 h-12 rounded-full border border-forest/20 flex items-center justify-center hover:bg-white transition-colors\" data-kid=\"55\"><i class=\"ti ti-chevron-left\" data-kid=\"56\"></i></button>\n          <button class=\"w-12 h-12 rounded-full border border-forest/20 flex items-center justify-center hover:bg-white transition-colors\" data-kid=\"57\"><i class=\"ti ti-chevron-right\" data-kid=\"58\"></i></button>\n        </div>\n      </div>\n\n      <div class=\"flex gap-8 overflow-x-auto hide-scrollbar pb-8\" data-kid=\"59\">\n        \n        <div class=\"property-card flex-shrink-0 w-[380px] bg-white rounded-[32px] overflow-hidden border border-forest/5 shadow-sm\" data-kid=\"60\">\n          <div class=\"relative h-[280px]\" data-kid=\"61\">\n            <img src=\"https://images.unsplash.com/photo-1502672260266-1c1ef2d93688?w=800&q=80\" class=\"w-full h-full object-cover\" alt=\"Modern Studio\" decoding=\"async\" loading=\"lazy\" data-kid=\"62\">\n            <div class=\"absolute top-4 left-4 bg-white/90 backdrop-blur-md px-3 py-1 rounded-full text-[10px] font-bold uppercase tracking-widest text-forest\" data-kid=\"63\">\n              Near Pulchowk\n            </div>\n            <button class=\"absolute top-4 right-4 w-10 h-10 rounded-full bg-white/20 backdrop-blur-md text-white flex items-center justify-center border border-white/30\" data-kid=\"64\">\n              <i class=\"ti ti-heart\" data-kid=\"65\"></i>\n            </button>\n          </div>\n          <div class=\"p-6\" data-kid=\"66\">\n            <div class=\"flex justify-between items-start mb-4\" data-kid=\"67\">\n              <div data-kid=\"68\">\n                <h3 class=\"font-display text-xl font-bold\" data-kid=\"69\">The Sunlit Studio</h3>\n                <p class=\"text-sm text-forest/60 font-medium\" data-kid=\"70\">Pulchowk, Lalitpur</p>\n              </div>\n              <div class=\"text-right\" data-kid=\"71\">\n                <span class=\"text-xl font-bold text-terracotta\" data-kid=\"72\">NPR 15k</span>\n                <p class=\"text-[10px] font-bold uppercase tracking-tighter text-forest/40\" data-kid=\"73\">per month</p>\n              </div>\n            </div>\n            \n            <div class=\"flex items-center gap-4 py-4 border-t border-forest/5\" data-kid=\"74\">\n              <div class=\"flex -space-x-2\" data-kid=\"75\">\n                <img src=\"https://i.pravatar.cc/100?u=x\" class=\"w-8 h-8 rounded-full border-2 border-white\" data-kid=\"76\">\n                <img src=\"https://i.pravatar.cc/100?u=y\" class=\"w-8 h-8 rounded-full border-2 border-white\" data-kid=\"77\">\n                <img src=\"https://i.pravatar.cc/100?u=z\" class=\"w-8 h-8 rounded-full border-2 border-white\" data-kid=\"78\">\n              </div>\n              <p class=\"text-xs font-bold text-forest/70\" data-kid=\"79\">Vouched for by 12 students</p>\n            </div>\n\n            <div class=\"flex items-center justify-between pt-2\" data-kid=\"80\">\n              <div class=\"flex items-center gap-2\" data-kid=\"81\">\n                <img src=\"https://i.pravatar.cc/100?u=rajesh\" class=\"w-6 h-6 rounded-full grayscale\" alt=\"Host\" data-kid=\"82\">\n                <span class=\"text-[10px] font-bold uppercase text-forest/40\" data-kid=\"83\">Host: Rajesh KC</span>\n              </div>\n              <div class=\"flex items-center gap-1 text-terracotta\" data-kid=\"84\">\n                <i class=\"ti ti-star-filled text-xs\" data-kid=\"85\"></i>\n                <span class=\"text-xs font-bold\" data-kid=\"86\">4.9</span>\n              </div>\n            </div>\n          </div>\n        </div>\n\n        \n        <div class=\"property-card flex-shrink-0 w-[380px] bg-white rounded-[32px] overflow-hidden border border-forest/5 shadow-sm\" data-kid=\"87\">\n          <div class=\"relative h-[280px]\" data-kid=\"88\">\n            <img src=\"https://images.pexels.com/photos/5137986/pexels-photo-5137986.jpeg?w=800&q=80\" class=\"w-full h-full object-cover\" alt=\"Dorm Room\" decoding=\"async\" loading=\"lazy\" data-kid=\"89\">\n            <div class=\"absolute top-4 left-4 bg-white/90 backdrop-blur-md px-3 py-1 rounded-full text-[10px] font-bold uppercase tracking-widest text-forest\" data-kid=\"90\">\n              Near TU Baneshwor\n            </div>\n            <button class=\"absolute top-4 right-4 w-10 h-10 rounded-full bg-white/20 backdrop-blur-md text-white flex items-center justify-center border border-white/30\" data-kid=\"91\">\n              <i class=\"ti ti-heart\" data-kid=\"92\"></i>\n            </button>\n          </div>\n          <div class=\"p-6\" data-kid=\"93\">\n            <div class=\"flex justify-between items-start mb-4\" data-kid=\"94\">\n              <div data-kid=\"95\">\n                <h3 class=\"font-display text-xl font-bold\" data-kid=\"96\">Modern Shared Loft</h3>\n                <p class=\"text-sm text-forest/60 font-medium\" data-kid=\"97\">New Baneshwor, KTM</p>\n              </div>\n              <div class=\"text-right\" data-kid=\"98\">\n                <span class=\"text-xl font-bold text-terracotta\" data-kid=\"99\">NPR 8.5k</span>\n                <p class=\"text-[10px] font-bold uppercase tracking-tighter text-forest/40\" data-kid=\"100\">per month</p>\n              </div>\n            </div>\n            \n            <div class=\"flex items-center gap-4 py-4 border-t border-forest/5\" data-kid=\"101\">\n              <div class=\"flex -space-x-2\" data-kid=\"102\">\n                <img src=\"https://i.pravatar.cc/100?u=1\" class=\"w-8 h-8 rounded-full border-2 border-white\" data-kid=\"103\">\n                <img src=\"https://i.pravatar.cc/100?u=2\" class=\"w-8 h-8 rounded-full border-2 border-white\" data-kid=\"104\">\n              </div>\n              <p class=\"text-xs font-bold text-forest/70\" data-kid=\"105\">8 people recently viewed</p>\n            </div>\n\n            <div class=\"flex items-center justify-between pt-2\" data-kid=\"106\">\n              <div class=\"flex items-center gap-2\" data-kid=\"107\">\n                <img src=\"https://i.pravatar.cc/100?u=sita\" class=\"w-6 h-6 rounded-full grayscale\" alt=\"Host\" data-kid=\"108\">\n                <span class=\"text-[10px] font-bold uppercase text-forest/40\" data-kid=\"109\">Host: Sita Thapa</span>\n              </div>\n              <div class=\"flex items-center gap-1 text-terracotta\" data-kid=\"110\">\n                <i class=\"ti ti-star-filled text-xs\" data-kid=\"111\"></i>\n                <span class=\"text-xs font-bold\" data-kid=\"112\">4.7</span>\n              </div>\n            </div>\n          </div>\n        </div>\n\n        \n        <div class=\"property-card flex-shrink-0 w-[380px] bg-white rounded-[32px] overflow-hidden border border-forest/5 shadow-sm\" data-kid=\"113\">\n          <div class=\"relative h-[280px]\" data-kid=\"114\">\n            <img src=\"https://images.pexels.com/photos/31077121/pexels-photo-31077121.jpeg?w=800&q=80\" class=\"w-full h-full object-cover\" alt=\"Hostel Room\" decoding=\"async\" loading=\"lazy\" data-kid=\"115\">\n            <div class=\"absolute top-4 left-4 bg-white/90 backdrop-blur-md px-3 py-1 rounded-full text-[10px] font-bold uppercase tracking-widest text-forest\" data-kid=\"116\">\n              Near KU Dhulikhel\n            </div>\n          </div>\n          <div class=\"p-6\" data-kid=\"117\">\n            <div class=\"flex justify-between items-start mb-4\" data-kid=\"118\">\n              <div data-kid=\"119\">\n                <h3 class=\"font-display text-xl font-bold\" data-kid=\"120\">Dhulikhel Retreat</h3>\n                <p class=\"text-sm text-forest/60 font-medium\" data-kid=\"121\">Dhulikhel, Kavre</p>\n              </div>\n              <div class=\"text-right\" data-kid=\"122\">\n                <span class=\"text-xl font-bold text-terracotta\" data-kid=\"123\">NPR 12k</span>\n                <p class=\"text-[10px] font-bold uppercase tracking-tighter text-forest/40\" data-kid=\"124\">per month</p>\n              </div>\n            </div>\n            \n            <div class=\"flex items-center gap-4 py-4 border-t border-forest/5\" data-kid=\"125\">\n              <div class=\"flex -space-x-2\" data-kid=\"126\">\n                <img src=\"https://i.pravatar.cc/100?u=a\" class=\"w-8 h-8 rounded-full border-2 border-white\" data-kid=\"127\">\n                <img src=\"https://i.pravatar.cc/100?u=b\" class=\"w-8 h-8 rounded-full border-2 border-white\" data-kid=\"128\">\n              </div>\n              <p class=\"text-xs font-bold text-forest/70\" data-kid=\"129\">Verified by KU Students</p>\n            </div>\n\n            <div class=\"flex items-center justify-between pt-2\" data-kid=\"130\">\n              <div class=\"flex items-center gap-2\" data-kid=\"131\">\n                <img src=\"https://i.pravatar.cc/100?u=binod\" class=\"w-6 h-6 rounded-full grayscale\" alt=\"Host\" data-kid=\"132\">\n                <span class=\"text-[10px] font-bold uppercase text-forest/40\" data-kid=\"133\">Host: Binod Lama</span>\n              </div>\n              <div class=\"flex items-center gap-1 text-terracotta\" data-kid=\"134\">\n                <i class=\"ti ti-star-filled text-xs\" data-kid=\"135\"></i>\n                <span class=\"text-xs font-bold\" data-kid=\"136\">5.0</span>\n              </div>\n            </div>\n          </div>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  \n  <section class=\"container mx-auto px-8 py-24\" data-kid=\"137\">\n    <div class=\"bg-forest rounded-[48px] p-12 lg:p-20 text-bone relative overflow-hidden\" data-kid=\"138\">\n      \n      <div class=\"absolute top-0 right-0 w-96 h-96 bg-terracotta/20 blur-[100px] -mr-48 -mt-48 rounded-full\" data-kid=\"139\"></div>\n      <div class=\"absolute bottom-0 left-0 w-64 h-64 bg-sand/10 blur-[80px] -ml-32 -mb-32 rounded-full\" data-kid=\"140\"></div>\n\n      <div class=\"relative z-10 grid lg:grid-cols-2 gap-16 items-center\" data-kid=\"141\">\n        <div data-kid=\"142\">\n          <h2 class=\"font-display text-5xl lg:text-6xl font-bold mb-8 leading-tight\" data-kid=\"143\">\n            Can't find the <span class=\"italic text-terracotta\" data-kid=\"144\">perfect</span> match?\n          </h2>\n          <p class=\"text-xl text-bone/70 mb-12 leading-relaxed\" data-kid=\"145\">\n            Our AI Concierge understands student life. Tell us your budget, your college, and your lifestyle, and we'll hand-pick the best spaces for you.\n          </p>\n          <div class=\"space-y-4\" data-kid=\"146\">\n            <div class=\"flex items-center gap-4 bg-white/5 border border-white/10 p-4 rounded-2xl\" data-kid=\"147\">\n              <div class=\"w-10 h-10 rounded-full bg-terracotta flex items-center justify-center font-bold\" data-kid=\"148\">S</div>\n              <p class=\"text-sm font-medium\" data-kid=\"149\">\"I need a quiet room near Pulchowk Campus under 10k with high-speed WiFi.\"</p>\n            </div>\n            <div class=\"flex items-center gap-4 bg-white/10 border border-white/20 p-4 rounded-2xl ml-8\" data-kid=\"150\">\n              <div class=\"w-10 h-10 rounded-full bg-forest border border-bone/20 flex items-center justify-center\" data-kid=\"151\"><i class=\"ti ti-message-chatbot\" data-kid=\"152\"></i></div>\n              <p class=\"text-sm font-medium italic\" data-kid=\"153\">\"I've found 3 verified apartments that fit your criteria perfectly. Would you like a virtual tour?\"</p>\n            </div>\n          </div>\n        </div>\n        \n        <div class=\"bg-white/5 backdrop-blur-md rounded-[32px] p-8 border border-white/10 shadow-2xl\" data-kid=\"154\">\n          <h4 class=\"font-display text-2xl font-bold mb-6\" data-kid=\"155\">Start your search</h4>\n          <div class=\"space-y-6\" data-kid=\"156\">\n            <div class=\"space-y-2\" data-kid=\"157\">\n              <label class=\"text-[10px] font-bold uppercase tracking-widest text-bone/40\" data-kid=\"158\">Your College</label>\n              <select class=\"w-full bg-white/10 border-none outline-none rounded-xl p-4 text-sm font-medium\" data-kid=\"159\">\n                <option data-kid=\"160\">Pulchowk Engineering Campus</option>\n                <option data-kid=\"161\">Kathmandu University</option>\n              </select>\n            </div>\n            <div class=\"space-y-2\" data-kid=\"162\">\n              <label class=\"text-[10px] font-bold uppercase tracking-widest text-bone/40\" data-kid=\"163\">Monthly Budget</label>\n              <div class=\"flex items-center gap-4\" data-kid=\"164\">\n                <input type=\"range\" class=\"flex-1 accent-terracotta\" data-kid=\"165\">\n                <span class=\"font-bold text-terracotta\" data-kid=\"166\">NPR 12k</span>\n              </div>\n            </div>\n            <div class=\"space-y-2\" data-kid=\"167\">\n              <label class=\"text-[10px] font-bold uppercase tracking-widest text-bone/40\" data-kid=\"168\">What's important to you?</label>\n              <div class=\"flex flex-wrap gap-2\" data-kid=\"169\">\n                <button class=\"px-4 py-2 rounded-full bg-white/10 text-xs font-bold border border-white/10 hover:bg-terracotta transition-colors\" data-kid=\"170\">Quiet Study</button>\n                <button class=\"px-4 py-2 rounded-full bg-white/10 text-xs font-bold border border-white/10 hover:bg-terracotta transition-colors\" data-kid=\"171\">Fast WiFi</button>\n                <button class=\"px-4 py-2 rounded-full bg-white/10 text-xs font-bold border border-white/10 hover:bg-terracotta transition-colors\" data-kid=\"172\">Shared Kitchen</button>\n                <button class=\"px-4 py-2 rounded-full bg-white/10 text-xs font-bold border border-white/10 hover:bg-terracotta transition-colors\" data-kid=\"173\">Terrace</button>\n              </div>\n            </div>\n            <button class=\"w-full bg-terracotta py-4 rounded-xl font-bold text-lg hover:shadow-lg shadow-terracotta/20 transition-all\" data-kid=\"174\">\n              Find my Perfect Room\n            </button>\n          </div>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  \n  <footer class=\"bg-forest pt-24 pb-12 text-bone/40\" data-kid=\"175\">\n    <div class=\"container mx-auto px-8 grid md:grid-cols-4 gap-12 mb-24\" data-kid=\"176\">\n      <div class=\"col-span-2 space-y-6\" data-kid=\"177\">\n        <a href=\"#\" class=\"font-display text-3xl font-bold text-bone tracking-tight\" data-kid=\"178\">RoomSathi</a>\n        <p class=\"max-w-xs text-sm leading-relaxed\" data-kid=\"179\">\n          Crafting the future of student living in Nepal. A human-centric marketplace built on trust, community, and transparency.\n        </p>\n        <div class=\"flex gap-4\" data-kid=\"180\">\n          <a href=\"#\" class=\"w-10 h-10 rounded-full border border-white/10 flex items-center justify-center hover:text-bone transition-colors\" data-kid=\"181\"><i class=\"ti ti-brand-instagram\" data-kid=\"182\"></i></a>\n          <a href=\"#\" class=\"w-10 h-10 rounded-full border border-white/10 flex items-center justify-center hover:text-bone transition-colors\" data-kid=\"183\"><i class=\"ti ti-brand-twitter\" data-kid=\"184\"></i></a>\n          <a href=\"#\" class=\"w-10 h-10 rounded-full border border-white/10 flex items-center justify-center hover:text-bone transition-colors\" data-kid=\"185\"><i class=\"ti ti-brand-facebook\" data-kid=\"186\"></i></a>\n        </div>\n      </div>\n      <div data-kid=\"187\">\n        <h5 class=\"text-bone font-bold text-xs uppercase tracking-widest mb-6\" data-kid=\"188\">Explore</h5>\n        <ul class=\"space-y-4 text-sm font-medium\" data-kid=\"189\">\n          <li data-kid=\"190\"><a href=\"#\" class=\"hover:text-bone transition-colors\" data-kid=\"191\">Browse Rooms</a></li>\n          <li data-kid=\"192\"><a href=\"#\" class=\"hover:text-bone transition-colors\" data-kid=\"193\">Campus Favorites</a></li>\n          <li data-kid=\"194\"><a href=\"#\" class=\"hover:text-bone transition-colors\" data-kid=\"195\">Roommate Matching</a></li>\n          <li data-kid=\"196\"><a href=\"#\" class=\"hover:text-bone transition-colors\" data-kid=\"197\">AI